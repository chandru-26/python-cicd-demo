# =============================================================================
# .gitignore - Python CI/CD Demo Project
# =============================================================================

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
*.manifest
*.spec

# Virtual Environments
venv/
env/
.env/
.venv/

# =============================================================================
# Testing
# =============================================================================
.coverage
htmlcov/
.pytest_cache/
reports/
coverage-html/
*.xml

# =============================================================================
# IDE
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~

# =============================================================================
# OS Files
# =============================================================================
.DS_Store
Thumbs.db
*.log

# =============================================================================
# Docker
# =============================================================================
.docker/

# =============================================================================
# Environment Files (NEVER commit secrets!)
# =============================================================================
.env
.env.local
.env.production
*.pem
*.key

# =============================================================================
# Kubernetes
# =============================================================================
# Never commit actual secret values
# k8s/secret-values.yaml

# =============================================================================
# Build Artifacts
# =============================================================================
*.tar.gz
*.zip

